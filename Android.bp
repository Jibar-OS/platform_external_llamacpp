// llama.cpp static library for AOSP
// Built from upstream llama.cpp source with Android-specific config.
//
// Upstream: https://github.com/ggerganov/llama.cpp
//
// To update llama.cpp:
//   1. Download new release tarball
//   2. Extract to src/
//   3. Run: bash scripts/sync_upstream.sh
//   4. Test build: m libllama

cc_library_static {
    name: "libllama",
    vendor_available: true,
    product_available: true,

    // Source list for llama.cpp b4547+.
    // After running sync_upstream.sh, verify against actual src/ layout:
    //   find src/ggml/src -name '*.c' -o -name '*.cpp'
    //   find src/src -name '*.cpp'
    // Not all files are needed — only core inference, no server/CLI code.
    srcs: [
        // ggml core (verified against b4547)
        "src/ggml/src/ggml.c",
        "src/ggml/src/ggml-alloc.c",
        "src/ggml/src/ggml-backend.cpp",
        "src/ggml/src/ggml-backend-reg.cpp",
        "src/ggml/src/ggml-quants.c",
        "src/ggml/src/ggml-threading.cpp",
        "src/ggml/src/gguf.cpp",
        // ggml CPU backend
        "src/ggml/src/ggml-cpu/ggml-cpu-impl.c",
        "src/ggml/src/ggml-cpu/ggml-cpu.cpp",
        "src/ggml/src/ggml-cpu/ggml-cpu-quants.c",
        "src/ggml/src/ggml-cpu/ggml-cpu-aarch64.cpp",
        "src/ggml/src/ggml-cpu/ggml-cpu-traits.cpp",
        // llama core
        "src/src/llama.cpp",
        "src/src/llama-arch.cpp",
        "src/src/llama-adapter.cpp",
        "src/src/llama-batch.cpp",
        "src/src/llama-chat.cpp",
        "src/src/llama-context.cpp",
        "src/src/llama-cparams.cpp",
        "src/src/llama-grammar.cpp",
        "src/src/llama-hparams.cpp",
        "src/src/llama-impl.cpp",
        "src/src/llama-kv-cache.cpp",
        "src/src/llama-mmap.cpp",
        "src/src/llama-model.cpp",
        "src/src/llama-model-loader.cpp",
        "src/src/llama-quant.cpp",
        "src/src/llama-sampling.cpp",
        "src/src/llama-vocab.cpp",
        "src/src/unicode.cpp",
        "src/src/unicode-data.cpp",
        // common utilities (only what we need for inference)
        
    ],

    local_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/ggml/src",
        "src/ggml/src/ggml-cpu",
        "src/src",
        "src/common",
    ],

    cflags: [
        "-DNDEBUG",
        "-DGGML_USE_CPU",
        "-D_GNU_SOURCE",
        "-O3",
        "-fPIC",
        "-pthread",
        // ARM NEON is enabled by default on aarch64
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
        "-Wno-unused-function",
        "-Wno-missing-field-initializers",
        "-Wno-implicit-fallthrough",
    ],

    arch: {
        arm64: {
            cflags: [
                "-DGGML_USE_CPU_AARCH64",
                "-mcpu=cortex-a76",
            ],
        },
        x86_64: {
            cflags: [
                "-mavx2",
                "-mfma",
                "-mf16c",
            ],
        },
    },

    // Cuttlefish (x86_64) and real devices (arm64) both supported
    compile_multilib: "both",

    stl: "c++_shared",

    export_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/common",
    ],
}

// JNI shared library used by LlmManagerService inside system_server.
//
// Installs to /system/lib64. To get it into the system image, this lib's
// name (libllm_jni) must appear in PRODUCT_PACKAGES — wired in
// build/make/target/product/handheld_system_ext.mk.
//
// LlmManagerService loads this via System.loadLibrary("llm_jni"). A
// /data/local/llm/libllm_jni.so fallback exists in the static{} block
// for dev builds where the lib isn't yet baked into the image; that
// fallback can be removed once the install rule is in place everywhere.
cc_library_shared {
    name: "libllm_jni",

    // No vendor_available / product_available — this is system_server-only.
    // Installs to /system/lib64 by default.

    srcs: [
        "jni/llm_jni.cpp",
    ],

    shared_libs: [
        "liblog",
    ],

    static_libs: [
        "libllama",
    ],

    local_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/common",
    ],

    cflags: [
        "-DNDEBUG",
        "-O3",
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
    ],

    header_libs: ["jni_headers"],

    stl: "c++_shared",

    // Build only the 64-bit variant. system_server is 64-bit on every
    // device AAOSP targets; building the x86 variant just wastes time
    // and disk.
    compile_multilib: "64",
}
