// llama.cpp static library for AOSP
// Built from upstream llama.cpp source with Android-specific config.
//
// Upstream: https://github.com/ggml-org/llama.cpp
// Pin:      b8720 (2026-04-09)
//
// To update llama.cpp:
//   1. Edit version.txt — set the new tag (single source of truth;
//      consumed by both this Android.bp via the genrule below AND by
//      scripts/sync_upstream.sh).
//   2. Run: bash scripts/sync_upstream.sh
//   3. Verify source inventory against srcs: block below
//   4. Test build: m libllama libmtmd

// Inject GGML_VERSION + GGML_COMMIT macros that ggml.c expects
// (ggml_version() / ggml_commit() return them via const char*).
// Upstream uses CMake target_compile_definitions; Soong has no
// equivalent so we generate a header at build time and force-include
// it into every TU that consumes the macros.
genrule {
    name: "ggml-version-header",
    srcs: ["version.txt"],
    out: ["llamacpp_version.h"],
    cmd: "v=\"$$(cat $(in) | tr -d '[:space:]')\" && " +
         "printf '#define GGML_VERSION \"%s\"\\n#define GGML_COMMIT \"%s\"\\n' \"$$v\" \"$$v\" > $(out)",
}

cc_library_static {
    name: "libllama",
    vendor_available: true,
    product_available: true,

    // Source list for llama.cpp b8720.
    // After running sync_upstream.sh, verify against actual src/ layout:
    //   find src/ggml/src -maxdepth 2 -name '*.c' -o -name '*.cpp'
    //   find src/src -name '*.cpp'
    srcs: [
        // ggml core. Note: ggml.cpp and ggml-cpu.cpp live in the
        // libllama_cxx_companions module below — Soong's per-file
        // intermediate-object naming uses the basename without the
        // extension, so co-located ggml.c + ggml.cpp both produce
        // ggml.o and conflict ([-w dupbuild=err]). Splitting the
        // .cpp companions into a separate cc_library_static gives
        // each its own intermediates dir.
        "src/ggml/src/ggml.c",
        "src/ggml/src/ggml-alloc.c",
        "src/ggml/src/ggml-backend.cpp",
        "src/ggml/src/ggml-backend-reg.cpp",
        "src/ggml/src/ggml-backend-dl.cpp",
        "src/ggml/src/ggml-opt.cpp",
        "src/ggml/src/ggml-quants.c",
        "src/ggml/src/ggml-threading.cpp",
        "src/ggml/src/gguf.cpp",
        // ggml CPU backend — new structure in b8720 splits ops across
        // multiple TUs; arch-specific SIMD lives under arch/<arch>/.
        "src/ggml/src/ggml-cpu/ggml-cpu.c",
        "src/ggml/src/ggml-cpu/binary-ops.cpp",
        "src/ggml/src/ggml-cpu/unary-ops.cpp",
        "src/ggml/src/ggml-cpu/ops.cpp",
        "src/ggml/src/ggml-cpu/hbm.cpp",
        "src/ggml/src/ggml-cpu/quants.c",
        "src/ggml/src/ggml-cpu/repack.cpp",
        "src/ggml/src/ggml-cpu/traits.cpp",
        "src/ggml/src/ggml-cpu/vec.cpp",
        // llama core — b8720 adds graph/io/memory* and renames
        // llama-sampling.cpp -> llama-sampler.cpp.
        "src/src/llama.cpp",
        "src/src/llama-adapter.cpp",
        "src/src/llama-arch.cpp",
        "src/src/llama-batch.cpp",
        "src/src/llama-chat.cpp",
        "src/src/llama-context.cpp",
        "src/src/llama-cparams.cpp",
        "src/src/llama-grammar.cpp",
        "src/src/llama-graph.cpp",
        "src/src/llama-hparams.cpp",
        "src/src/llama-impl.cpp",
        "src/src/llama-io.cpp",
        "src/src/llama-kv-cache.cpp",
        "src/src/llama-kv-cache-iswa.cpp",
        "src/src/llama-memory.cpp",
        "src/src/llama-memory-hybrid.cpp",
        "src/src/llama-memory-hybrid-iswa.cpp",
        "src/src/llama-memory-recurrent.cpp",
        "src/src/llama-mmap.cpp",
        "src/src/llama-model-loader.cpp",
        "src/src/llama-model.cpp",
        "src/src/llama-model-saver.cpp",
        "src/src/llama-quant.cpp",
        "src/src/llama-sampler.cpp",
        "src/src/llama-vocab.cpp",
        "src/src/unicode.cpp",
        "src/src/unicode-data.cpp",
    ],

    arch: {
        arm64: {
            srcs: [
                // ARM-specific CPU SIMD. Actual file list verified at
                // Phase C time against src/ggml/src/ggml-cpu/arch/arm/.
                "src/ggml/src/ggml-cpu/arch/arm/quants.c",
                "src/ggml/src/ggml-cpu/arch/arm/repack.cpp",
            ],
            cflags: [
                "-DGGML_USE_CPU_AARCH64",
                "-mcpu=cortex-a76",
            ],
        },
        x86_64: {
            srcs: [
                "src/ggml/src/ggml-cpu/arch/x86/quants.c",
                "src/ggml/src/ggml-cpu/arch/x86/repack.cpp",
            ],
            cflags: [
                "-mavx2",
                "-mfma",
                "-mf16c",
            ],
        },
    },

    local_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/ggml/src",
        "src/ggml/src/ggml-cpu",
        "src/src",
        "src/common",
    ],

    generated_headers: ["ggml-version-header"],

    cflags: [
        "-DNDEBUG",
        "-DGGML_USE_CPU",
        "-D_GNU_SOURCE",
        // Force-include the generated header so ggml_version() /
        // ggml_commit() pick up GGML_VERSION / GGML_COMMIT without us
        // patching upstream ggml.c. Source of truth: version.txt at
        // repo root, consumed by the ggml-version-header genrule.
        "-include llamacpp_version.h",
        "-O3",
        "-fPIC",
        "-pthread",
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
        "-Wno-unused-function",
        "-Wno-unused-variable",
        "-Wno-unused-but-set-variable",
        "-Wno-missing-field-initializers",
        "-Wno-implicit-fallthrough",
        "-Wno-cast-function-type",
        "-Wno-deprecated-declarations",
        // Vendored upstream gguf.cpp + others define classes with virtual
        // methods and defaulted dtors. AOSP defaults to -Werror=non-virtual-dtor;
        // demote to a plain warning so we keep the upstream code unmodified.
        "-Wno-error=non-virtual-dtor",
    ],

    compile_multilib: "both",
    stl: "c++_shared",

    export_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/common",
    ],

    whole_static_libs: ["libllama_cxx_companions"],
}

// Holds the small (~25-line) C++ companion files for ggml. They live
// alongside their .c counterparts (e.g. ggml.c + ggml.cpp at the same
// path) and Soong's basename-keyed object naming refuses to compile
// both into the same module. Splitting them into this module gives
// each .cpp a unique intermediates path; libllama whole_static_libs
// pulls them in transparently.
cc_library_static {
    name: "libllama_cxx_companions",
    vendor_available: true,
    product_available: true,

    srcs: [
        "src/ggml/src/ggml.cpp",
        "src/ggml/src/ggml-cpu/ggml-cpu.cpp",
    ],

    local_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/ggml/src",
        "src/ggml/src/ggml-cpu",
        "src/src",
        "src/common",
    ],

    generated_headers: ["ggml-version-header"],

    cflags: [
        "-DNDEBUG",
        "-DGGML_USE_CPU",
        "-D_GNU_SOURCE",
        // Force-include the generated header so ggml_version() /
        // ggml_commit() pick up GGML_VERSION / GGML_COMMIT without us
        // patching upstream ggml.c. Source of truth: version.txt at
        // repo root, consumed by the ggml-version-header genrule.
        "-include llamacpp_version.h",
        "-O3",
        "-fPIC",
        "-pthread",
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
        "-Wno-unused-function",
        "-Wno-unused-variable",
        "-Wno-unused-but-set-variable",
        "-Wno-missing-field-initializers",
        "-Wno-implicit-fallthrough",
        "-Wno-cast-function-type",
        "-Wno-deprecated-declarations",
        // Vendored upstream gguf.cpp + others define classes with virtual
        // methods and defaulted dtors. AOSP defaults to -Werror=non-virtual-dtor;
        // demote to a plain warning so we keep the upstream code unmodified.
        "-Wno-error=non-virtual-dtor",
    ],

    compile_multilib: "both",
    stl: "c++_shared",
}

// v0.5 V1: libmtmd replaces v0.4's libllava (PR #12849 upstream).
// Provides mtmd_context / mtmd_bitmap / mtmd_input_chunks API for
// vision.describe (image encoding + tokenization + LLM input chunk
// preparation). Also includes clip.cpp which survives as the image
// encoder backbone, exported for potential use by vision.embed in V10.
// Separate static_lib so libllama stays lean; only oird links libmtmd.
cc_library_static {
    name: "libmtmd",
    vendor_available: true,
    product_available: true,

    srcs: [
        "src/tools/mtmd/clip.cpp",
        "src/tools/mtmd/mtmd.cpp",
        "src/tools/mtmd/mtmd-audio.cpp",
        "src/tools/mtmd/mtmd-helper.cpp",
        "src/tools/mtmd/mtmd-image.cpp",
        // Per-model adapter implementations (b8720 split clip.cpp).
        "src/tools/mtmd/models/cogvlm.cpp",
        "src/tools/mtmd/models/conformer.cpp",
        "src/tools/mtmd/models/deepseekocr.cpp",
        "src/tools/mtmd/models/gemma4v.cpp",
        "src/tools/mtmd/models/glm4v.cpp",
        "src/tools/mtmd/models/hunyuanocr.cpp",
        "src/tools/mtmd/models/internvl.cpp",
        "src/tools/mtmd/models/kimik25.cpp",
        "src/tools/mtmd/models/kimivl.cpp",
        "src/tools/mtmd/models/llama4.cpp",
        "src/tools/mtmd/models/llava.cpp",
        "src/tools/mtmd/models/minicpmv.cpp",
        "src/tools/mtmd/models/mobilenetv5.cpp",
        "src/tools/mtmd/models/nemotron-v2-vl.cpp",
        "src/tools/mtmd/models/paddleocr.cpp",
        "src/tools/mtmd/models/pixtral.cpp",
        "src/tools/mtmd/models/qwen2vl.cpp",
        "src/tools/mtmd/models/qwen3vl.cpp",
        "src/tools/mtmd/models/siglip.cpp",
        "src/tools/mtmd/models/step3vl.cpp",
        "src/tools/mtmd/models/whisper-enc.cpp",
        "src/tools/mtmd/models/youtuvl.cpp",
    ],

    local_include_dirs: [
        "src/tools/mtmd",
        "src/include",
        "src/ggml/include",
        "src/common",
        "src/src",
        "src/vendor",
    ],

    export_include_dirs: [
        "src/tools/mtmd",
    ],

    // mtmd + clip depend on llama headers + ggml headers; static-link
    // libllama so dependents don't need to declare both.
    static_libs: [
        "libllama",
    ],

    cflags: [
        "-DNDEBUG",
        "-DGGML_USE_CPU",
        "-D_GNU_SOURCE",
        "-O3",
        "-fPIC",
        "-pthread",
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
        "-Wno-unused-function",
        "-Wno-unused-variable",
        "-Wno-unused-but-set-variable",
        "-Wno-missing-field-initializers",
        "-Wno-implicit-fallthrough",
        "-Wno-cast-function-type",
    ],

    stl: "c++_shared",
    compile_multilib: "64",
}

// JNI shared library — kept for AAOSP-era compat. OIR's oird does not
// use libllm_jni; it links libllama directly in its own Android.bp.
// Considered removable in a later cleanup if no other consumer surfaces.
cc_library_shared {
    name: "libllm_jni",
    srcs: ["jni/llm_jni.cpp"],
    shared_libs: ["liblog"],
    static_libs: ["libllama"],
    local_include_dirs: [
        "src/include",
        "src/ggml/include",
        "src/common",
    ],
    cflags: [
        "-DNDEBUG",
        "-O3",
        "-Wall",
        "-fexceptions",
        "-frtti",
        "-Wno-unused-parameter",
    ],
    header_libs: ["jni_headers"],
    stl: "c++_shared",
    compile_multilib: "64",
}
